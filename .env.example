# ─────────────────────────────────────────────────────────────────────────────
# Pixela Go backend — example environment.
# Copy to `.env` for local dev. NEVER commit the real `.env` (see .gitignore).
# Dev defaults below match docker-compose.dev.yml. Secrets are placeholders.
#
# The binary does NOT read `.env` itself (12-factor; see go-backend.md §11.2):
# docker-compose / your shell / direnv injects these. Config is parsed + validated
# once at startup via caarlos0/env; missing required secrets fail fast.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime env — switches slog handler (text in dev, JSON in prod) and CORS strictness.
PIXELA_ENV=development
PORT=3000
# Log verbosity: debug | info | warn | error.
LOG_LEVEL=debug
# Allowed CORS origin for the dashboard (Angular dev server / prod host).
CORS_ORIGIN=http://localhost:4200

# Process mode is chosen by SUBCOMMAND, not env: `pixela serve | worker | migrate`
# (one image, two modes via docker `command:`). There is no API_MODE flag.

# ── Local infra host ports (docker-compose.dev.yml) ──────────────────────────
# Defaults match the spec. Override only if these ports are taken by other local
# stacks; then update DATABASE_URL / REDIS_URL / S3_ENDPOINT below to match.
PIXELA_PG_PORT=5432
PIXELA_REDIS_PORT=6379
PIXELA_MINIO_PORT=9000
PIXELA_MINIO_CONSOLE_PORT=9001

# ── Database (PostgreSQL) — also hosts the River job queue ───────────────────
DATABASE_URL=postgresql://pixela:pixela@localhost:5432/pixela

# ── Redis — dashboard SESSIONS ONLY (decision B-03) ──────────────────────────
# Not a queue (River runs on Postgres). Out of the data/queue path, in for sessions.
REDIS_URL=redis://localhost:6379

# ── Object storage (S3-compatible / MinIO) — content-addressable blobs ───────
S3_ENDPOINT=http://localhost:9000
# Browser-reachable origin used ONLY to sign presigned GET URLs (the dashboard fetches
# blobs directly). Empty ⇒ falls back to S3_ENDPOINT. Behind docker/NAT the API reaches
# MinIO internally (S3_ENDPOINT=http://minio:9000) while the browser needs a published
# host (e.g. http://localhost:19000); the signature is bound to this public host.
S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=pixela
S3_ACCESS_KEY=pixela
S3_SECRET_KEY=pixela-secret
# MinIO requires path-style addressing (no virtual-hosted buckets).
S3_FORCE_PATH_STYLE=true
# Use TLS for the S3 endpoint (false for local plaintext MinIO; true in prod).
S3_USE_SSL=false

# ── Ingestion limits / safety ────────────────────────────────────────────────
# Reject PNGs larger than this (bytes) → IMAGE_TOO_LARGE. Default 10 MiB.
IMAGE_MAX_BYTES=10485760
# Presigned read URLs are short-lived (seconds). Spec: ~1h.
PRESIGNED_TTL_SECONDS=3600

# ── Dashboard auth — server-side sessions in Redis (decision B-03) ───────────
# Secret used to sign session cookies. Generate a strong random value in prod.
SESSION_SECRET=change-me-please-32-bytes-min

# ── Dashboard public URL — target link for GitLab commit status (Mode A) ─────
# Externally-reachable base URL of the dashboard (e.g. https://pixela.internal). Used to
# build the "details" link on the GitLab MR commit status. Optional.
PUBLIC_URL=

# ── GitLab integration (status, MR comment, OAuth login, baseline commits) ───
GITLAB_BASE_URL=https://gitlab.com
# Token with api/write_repository scope (commit baselines, set commit status, comment MR).
# Empty ⇒ Mode A git-write-back and MR status are disabled (no-op). Wire a project with
# `pixela project set-gitlab <slug> <gitlab-project-id>` to enable.
GITLAB_TOKEN=
# GitLab OAuth application credentials for dashboard login (F-43). Optional.
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/gitlab/callback

# ── Notifications (optional; fire-and-forget) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
