# ─────────────────────────────────────────────────────────────────────────────
# Pixela backend — example environment.
# Copy to `.env` for local dev. NEVER commit the real `.env` (see .gitignore).
# Dev defaults below match docker-compose.dev.yml. Secrets are placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime mode: `http` (REST API) or `worker` (BullMQ diff consumer). One image, two modes.
API_MODE=http
NODE_ENV=development
PORT=3000
# Allowed CORS origin for the dashboard (Angular dev server / prod host).
CORS_ORIGIN=http://localhost:4200

# ── Local infra host ports (docker-compose.dev.yml) ──────────────────────────
# Defaults match the spec. Override only if these ports are taken by other local
# stacks; then update DATABASE_URL / REDIS_URL / S3_ENDPOINT below to match.
PIXELA_PG_PORT=5432
PIXELA_REDIS_PORT=6379
PIXELA_MINIO_PORT=9000
PIXELA_MINIO_CONSOLE_PORT=9001

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://pixela:pixela@localhost:5432/pixela

# ── Redis (BullMQ queue + server-side sessions) ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Object storage (S3-compatible / MinIO) — content-addressable blobs ───────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=pixela
S3_ACCESS_KEY=pixela
S3_SECRET_KEY=pixela-secret
# MinIO requires path-style addressing (no virtual-hosted buckets).
S3_FORCE_PATH_STYLE=true
# Presigned read URLs are short-lived (seconds). Spec: ~1h.
PRESIGNED_URL_TTL_SECONDS=3600

# ── Ingestion limits / safety ────────────────────────────────────────────────
# Reject PNGs larger than this (bytes) → IMAGE_TOO_LARGE. Default 10 MiB.
IMAGE_MAX_BYTES=10485760

# ── Dashboard auth — server-side sessions in Redis (decision B-03) ───────────
# Secret used to sign session cookies. Generate a strong random value in prod.
SESSION_SECRET=change-me-please-32-bytes-min

# ── GitLab integration (status, MR comment, OAuth login, baseline commits) ───
GITLAB_URL=https://gitlab.com
# Token with api/write_repository scope (commit baselines, set commit status, comment MR).
GITLAB_TOKEN=
# GitLab OAuth application credentials for dashboard login (F-43).
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/gitlab/callback

# ── Notifications (optional; fire-and-forget) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=
