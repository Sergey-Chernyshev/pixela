{
  "name": "pixela",
  "version": "0.0.0",
  "private": true,
  "description": "Pixela — self-hosted visual regression platform (monorepo: API/worker, Angular web, Playwright SDK)",
  "license": "MIT",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,mjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,mjs,json,md,yml,yaml}\"",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.dev.yml down",
    "dev:api": "pnpm --filter @pixela/api run start:dev",
    "dev:web": "pnpm --filter @pixela/web run start",
    "prisma:generate": "pnpm --filter @pixela/api run prisma:generate",
    "prisma:migrate": "pnpm --filter @pixela/api run prisma:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
